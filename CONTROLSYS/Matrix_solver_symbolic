    def update_matrix_size(self):
        rows = self.rows_spin.value()
        cols = self.cols_spin.value()
        self.matrix_widget.resize_grid(rows, cols + 1)
    
    def format_expr(self, expr):
        if expr is None:
            return "0"
        if self.rational_check.isChecked():
            expr = sp.nsimplify(expr)
        if self.factor_check.isChecked():
            expr = factor(expr)
        elif self.simplify_check.isChecked():
            expr = simplify(expr)
        return str(expr)
    
    def matrix_to_string(self, matrix, highlight_row=None):
        rows, cols = matrix.shape
        # Convert all to strings first to find widths
        str_matrix = []
        for r in range(rows):
            row_strs = []
            for c in range(cols):
                s = self.format_expr(matrix[r, c])
                row_strs.append(s)
            str_matrix.append(row_strs)
        
        # Find max width per column
        col_widths = [0] * cols
        for r in range(rows):
            for c in range(cols):
                col_widths[c] = max(col_widths[c], len(str_matrix[r][c]))
        
        # Add padding
        col_widths = [w + 2 for w in col_widths]
        
        lines = []
        for r in range(rows):
            parts = []
            for c in range(cols - 1):
                parts.append(str_matrix[r][c].center(col_widths[c]))
            # RHS
            rhs = str_matrix[r][-1].center(col_widths[-1])
            line = " | ".join([" ".join(parts), rhs])
            prefix = ">>> " if r == highlight_row else "    "
            lines.append(f"{prefix}[ {line} ]")
        return "\n".join(lines)
    
    def gaussian_elimination(self):
        M, error = self.matrix_widget.get_matrix()
        if error:
            QMessageBox.warning(self, "Input Error", error)
            return
        
        rows, cols = M.shape
        n = rows
        m = cols - 1
        
        steps = []
        steps.append("=" * 60)
        steps.append("SYMBOLIC GAUSSIAN ELIMINATION")
        steps.append("=" * 60)
        steps.append(f"Initial Augmented Matrix ({rows}×{cols}):")
        steps.append(self.matrix_to_string(M))
        
        pivot_row = 0
        for col in range(m):
            pivot_found = False
            for r in range(pivot_row, n):
                if M[r, col] != 0:
                    if r != pivot_row:
                        M.row_swap(r, pivot_row)
                        steps.append("")
                        steps.append(f"🔄 Swap R{r+1} ↔ R{pivot_row+1} (pivot in col {col+1})")
                        steps.append(self.matrix_to_string(M, pivot_row))
                    pivot_found = True
                    break
            
            if not pivot_found:
                steps.append("")
                steps.append(f"⚠ No pivot in column {col+1}, skipping...")
                continue
            
            pivot = M[pivot_row, col]
            if pivot != 1 and pivot != 0:
                M[pivot_row, :] = M[pivot_row, :] / pivot
                steps.append("")
                steps.append(f"➗ R{pivot_row+1} ← R{pivot_row+1} / ({self.format_expr(pivot)})")
                steps.append(self.matrix_to_string(M, pivot_row))
            
            for r in range(pivot_row + 1, n):
                factor = M[r, col]
                if factor != 0:
                    M[r, :] = M[r, :] - factor * M[pivot_row, :]
                    M[r, :] = sp.simplify(M[r, :])
                    steps.append("")
                    steps.append(f"➖ R{r+1} ← R{r+1} - ({self.format_expr(factor)})×R{pivot_row+1}")
                    steps.append(self.matrix_to_string(M, r))
            
            pivot_row += 1
            if pivot_row >= n:
                break
        
        steps.append("")
        steps.append("=" * 60)
        steps.append("ROW ECHELON FORM ACHIEVED")
        steps.append("=" * 60)
        steps.append(self.matrix_to_string(M))
        
        # FIX: Use setPlainText with actual newlines, not escaped \\n
        self.steps_text.setPlainText("\n".join(steps))
        self.result_text.setPlainText("Row Echelon Form computed.\nUse 'Solve' or 'RREF' for solutions.")
        self.current_matrix = M
    
    def show_rref(self):
        M, error = self.matrix_widget.get_matrix()
        if error:
            QMessageBox.warning(self, "Input Error", error)
            return
        
        steps = []
        steps.append("=" * 60)
        steps.append("REDUCED ROW ECHELON FORM (RREF)")
        steps.append("=" * 60)
        
        rref_matrix, pivot_cols = M.rref()
        
        steps.append("")
        steps.append("RREF Result:")
        steps.append(self.matrix_to_string(rref_matrix))
        steps.append(f"\nPivot columns: {[c+1 for c in pivot_cols]}")
        
        rows, cols = rref_matrix.shape
        m = cols - 1
        
        steps.append("")
        steps.append("-" * 40)
        steps.append("SOLUTION ANALYSIS")
        steps.append("-" * 40)
        
        inconsistent = False
        for r in range(rows):
            if all(rref_matrix[r, c] == 0 for c in range(m)) and rref_matrix[r, m] != 0:
                inconsistent = True
                steps.append(f"❌ Row {r+1}: 0 = {self.format_expr(rref_matrix[r, m])} → INCONSISTENT")
        
        if inconsistent:
            steps.append("")
            steps.append("❌ SYSTEM HAS NO SOLUTION")
        elif len(pivot_cols) < m:
            steps.append("")
            steps.append(f"⚠ Underdetermined: {m} variables, {len(pivot_cols)} pivots")
            steps.append("Free variables:")
            free_vars = [c for c in range(m) if c not in pivot_cols]
            for fv in free_vars:
                steps.append(f"  x{fv+1} = free parameter")
            
            steps.append("")
            steps.append("Basic variables in terms of free variables:")
            for r_idx, pc in enumerate(pivot_cols):
                expr = rref_matrix[r_idx, m]
                for c in free_vars:
                    coeff = rref_matrix[r_idx, c]
                    if coeff != 0:
                        expr = expr - coeff * sp.Symbol(f't{c+1}')
                steps.append(f"  x{pc+1} = {self.format_expr(expr)}")
        else:
            steps.append("")
            steps.append("✅ Unique solution:")
            for i, pc in enumerate(pivot_cols):
                steps.append(f"  x{pc+1} = {self.format_expr(rref_matrix[i, m])}")
        
        self.steps_text.setPlainText("\n".join(steps))
        self.result_text.setPlainText("RREF analysis complete.")
    
    def solve_system(self):
        M, error = self.matrix_widget.get_matrix()
        if error:
            QMessageBox.warning(self, "Input Error", error)
            return
        
        rows, cols = M.shape
        m = cols - 1
        
        var_names = [f'x{i+1}' for i in range(m)]
        vars = symbols(var_names)
        
        equations = []
        for r in range(rows):
            lhs = sum(M[r, c] * vars[c] for c in range(m))
            eq = Eq(lhs, M[r, m])
            equations.append(eq)
        
        result = []
        result.append("=" * 60)
        result.append("SYSTEM OF EQUATIONS")
        result.append("=" * 60)
        
        for i, eq in enumerate(equations):
            result.append(f"Eq {i+1}: {eq}")
        
        try:
            solution = solve(equations, vars, dict=True)
            
            result.append("")
            result.append("=" * 60)
            result.append("SOLUTION")
            result.append("=" * 60)
            
            if not solution:
                result.append("❌ No solution found (inconsistent)")
            elif len(solution) == 1:
                sol = solution[0]
                result.append("✅ Unique Solution:")
                for var in vars:
                    if var in sol:
                        val = sol[var]
                        result.append(f"  {var} = {self.format_expr(val)}")
                    else:
                        result.append(f"  {var} = 0")
            else:
                result.append(f"⚠ {len(solution)} solution forms")
                for i, sol in enumerate(solution[:3]):
                    result.append(f"\nForm {i+1}:")
                    for var, val in sol.items():
                        result.append(f"  {var} = {self.format_expr(val)}")
            
            if solution:
                result.append("")
                result.append("-" * 40)
                result.append("VERIFICATION")
                result.append("-" * 40)
                sol = solution[0]
                for i, eq in enumerate(equations):
                    lhs_val = eq.lhs.subs(sol)
                    rhs_val = eq.rhs
                    lhs_s = self.format_expr(simplify(lhs_val))
                    rhs_s = self.format_expr(simplify(rhs_val))
                    match = "✓" if simplify(lhs_val - rhs_val) == 0 else "✗"
                    result.append(f"Eq {i+1}: {lhs_s} = {rhs_s} {match}")
        
        except Exception as e:
            result.append("")
            result.append(f"❌ Error: {str(e)}")
            result.append("Try 'RREF Form' for parametric analysis.")
        
        self.result_text.setPlainText("\n".join(result))
    
