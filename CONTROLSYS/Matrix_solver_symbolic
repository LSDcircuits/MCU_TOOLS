class SymbolicMatrixCell(QLineEdit):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setAlignment(Qt.AlignCenter)
        self.setFont(QFont("Consolas", 11))
        self.setFixedSize(100, 40)
        self.setStyleSheet("""
            QLineEdit {
                border: 2px solid #4a5568;
                border-radius: 6px;
                background-color: #2d3748;
                color: #e2e8f0;
                padding: 4px;
            }
            QLineEdit:focus {
                border: 2px solid #63b3ed;
                background-color: #1a202c;
            }
        """)
    
    def get_expr(self):
        text = self.text().strip()
        if not text:
            return sp.Integer(0)
        try:
            return sp.sympify(text)
        except:
            return None
    
    def set_expr(self, expr):
        self.setText(str(expr))


class SymbolicMatrixGrid(QWidget):
    def __init__(self, rows, cols, parent=None):
        super().__init__(parent)
        self.rows = rows
        self.cols = cols
        self.cells = []
        self.layout = QGridLayout(self)
        self.layout.setSpacing(6)
        self.layout.setContentsMargins(10, 10, 10, 10)
        self.build_grid()
    
    def build_grid(self):
        while self.layout.count():
            item = self.layout.takeAt(0)
            if item.widget():
                item.widget().deleteLater()
        self.cells = []
        
        for r in range(self.rows):
            row_cells = []
            for c in range(self.cols):
                cell = SymbolicMatrixCell(self)
                self.layout.addWidget(cell, r, c)
                row_cells.append(cell)
                if c == self.cols - 2 and self.cols > 2:
                    cell.setStyleSheet(cell.styleSheet().replace(
                        "border: 2px solid #4a5568;",
                        "border: 2px solid #4a5568; border-right: 3px solid #fc8181;"
                    ))
            self.cells.append(row_cells)
    
    def resize_grid(self, rows, cols):
        self.rows = rows
        self.cols = cols
        self.build_grid()
    
    def get_matrix(self):
        matrix = []
        for r in range(self.rows):
            row = []
            for c in range(self.cols):
                val = self.cells[r][c].get_expr()
                if val is None:
                    return None, f"Invalid expression at row {r+1}, col {c+1}"
                row.append(val)
            matrix.append(row)
        return Matrix(matrix), None
    
    def set_matrix(self, matrix):
        rows, cols = matrix.shape
        if rows != self.rows or cols != self.cols:
            self.resize_grid(rows, cols)
        for r in range(rows):
            for c in range(cols):
                self.cells[r][c].set_expr(matrix[r, c])


